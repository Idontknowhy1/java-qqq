<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.jike.mapper.sys.SysAccountMapper">

    <sql id="selectComps">
        select
            id as id,
            account as account,
            password as password,
            role_id as roleId,
            locked as locked,
            memo as memo
        from tb_accounts
    </sql>

</mapper>